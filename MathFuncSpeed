--========================================================
-- STATE
--========================================================
local selectedFn = nil
local paramBoxes = {}
local durationBox = nil
local segmentPool = {}
local sampled = {min=0, max=1, values={}}
local running = false
local listButtons = {}

local function getParams()
    local p = {}
    for i, box in ipairs(paramBoxes) do
        p[i] = tonumber(box.Text) or selectedFn.params[i][2]
    end
    return p
end

local function getDuration()
    return math.max(tonumber(durationBox and durationBox.Text or "") or 10, 0.5)
end

--========================================================
-- GRAPH RENDERING (line segments from a frame pool)
--========================================================
local function drawGraph()
    if not selectedFn then return end
    local p, dur = getParams(), getDuration()
    local vals, vmin, vmax = {}, math.huge, -math.huge
    for i = 0, GRAPH_SAMPLES do
        local ok, v = pcall(selectedFn.f, (i/GRAPH_SAMPLES)*dur, p)
        v = (ok and typeof(v)=="number" and v==v) and math.clamp(v, -1e4, 1e4) or 0
        vals[i+1] = v
        vmin, vmax = math.min(vmin,v), math.max(vmax,v)
    end
    if vmax - vmin < 1e-3 then vmax = vmin + 1 end
    sampled = {min=vmin, max=vmax, values=vals}

    local w, h = graphArea.AbsoluteSize.X, graphArea.AbsoluteSize.Y
    for i = 1, GRAPH_SAMPLES do
        local seg = segmentPool[i]
        if not seg then
            seg = new("Frame", {BackgroundColor3=Color3.fromRGB(90,200,255), BorderSizePixel=0,
                AnchorPoint=Vector2.new(0.5,0.5), ZIndex=3}, graphArea)
            segmentPool[i] = seg
        end
        local x1 = (i-1)/GRAPH_SAMPLES*w
        local x2 = i/GRAPH_SAMPLES*w
        local y1 = h - ((vals[i]-vmin)/(vmax-vmin))*h
        local y2 = h - ((vals[i+1]-vmin)/(vmax-vmin))*h
        local dx, dy = x2-x1, y2-y1
        local len = math.sqrt(dx*dx + dy*dy)
        seg.Visible = true
        seg.Size = UDim2.fromOffset(math.max(len,1), 2)
        seg.Position = UDim2.fromOffset((x1+x2)/2, (y1+y2)/2)
        seg.Rotation = math.deg(math.atan2(dy, dx))
    end
    graphInfo.Text = string.format("%s | y: %.1f to %.1f | t: 0 to %.1fs", selectedFn.name, vmin, vmax, dur)
end

--========================================================
-- INPUT PANEL BUILD
--========================================================
local execBtn, stopBtn, loopBtn, loopOn = nil, nil, nil, false

local function buildInputs(fnDef)
    selectedFn = fnDef
    paramBoxes = {}
    for _, c in ipairs(inputPanel:GetChildren()) do
        if not c:IsA("UICorner") then c:Destroy() end
    end
    new("TextLabel", {Size=UDim2.new(1,-16,0,22), Position=UDim2.fromOffset(8,6), BackgroundTransparency=1,
        Text=fnDef.name, Font=Enum.Font.GothamBold, TextSize=15, TextColor3=Color3.fromRGB(90,200,255),
        TextXAlignment=Enum.TextXAlignment.Left}, inputPanel)

    local y = 32
    local function addRow(labelText, default)
        new("TextLabel", {Size=UDim2.fromOffset(80,22), Position=UDim2.fromOffset(8,y), BackgroundTransparency=1,
            Text=labelText, Font=Enum.Font.Gotham, TextSize=12, TextColor3=Color3.fromRGB(210,210,220),
            TextXAlignment=Enum.TextXAlignment.Left}, inputPanel)
        local box = new("TextBox", {Size=UDim2.fromOffset(80,22), Position=UDim2.fromOffset(92,y),
            BackgroundColor3=Color3.fromRGB(50,50,62), Text=tostring(default), Font=Enum.Font.Gotham,
            TextSize=13, TextColor3=Color3.new(1,1,1), BorderSizePixel=0, ClearTextOnFocus=false}, inputPanel)
        new("UICorner", {CornerRadius=UDim.new(0,4)}, box)
        box:GetPropertyChangedSignal("Text"):Connect(drawGraph)
        y += 28
        return box
    end

    for _, def in ipairs(fnDef.params) do
        table.insert(paramBoxes, addRow(def[1], def[2]))
    end
    durationBox = addRow("duration (s)", 10)

    execBtn = new("TextButton", {Size=UDim2.new(1,-16,0,28), Position=UDim2.new(0,8,1,-72),
        BackgroundColor3=Color3.fromRGB(60,160,90), Text="Execute", Font=Enum.Font.GothamBold,
        TextSize=14, TextColor3=Color3.new(1,1,1), BorderSizePixel=0}, inputPanel)
    new("UICorner", {CornerRadius=UDim.new(0,6)}, execBtn)

    stopBtn = new("TextButton", {Size=UDim2.new(0.5,-12,0,24), Position=UDim2.new(0,8,1,-38),
        BackgroundColor3=Color3.fromRGB(170,70,70), Text="Stop", Font=Enum.Font.GothamBold,
        TextSize=13, TextColor3=Color3.new(1,1,1), BorderSizePixel=0}, inputPanel)
    new("UICorner", {CornerRadius=UDim.new(0,6)}, stopBtn)

    loopBtn = new("TextButton", {Size=UDim2.new(0.5,-12,0,24), Position=UDim2.new(0.5,4,1,-38),
        BackgroundColor3=Color3.fromRGB(60,60,75), Text="Loop: OFF", Font=Enum.Font.GothamBold,
        TextSize=13, TextColor3=Color3.new(1,1,1), BorderSizePixel=0}, inputPanel)
    new("UICorner", {CornerRadius=UDim.new(0,6)}, loopBtn)

    loopBtn.MouseButton1Click:Connect(function()
        loopOn = not loopOn
        loopBtn.Text = loopOn and "Loop: ON" or "Loop: OFF"
        loopBtn.BackgroundColor3 = loopOn and Color3.fromRGB(90,120,200) or Color3.fromRGB(60,60,75)
    end)
    execBtn.MouseButton1Click:Connect(function() running = true end)
    stopBtn.MouseButton1Click:Connect(function() running = false end)
    drawGraph()
end


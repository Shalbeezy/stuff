--========================================================
-- FUNCTION LIBRARY  (p = parameter array, t = time)
--========================================================
local FUNCTIONS = {
    {name = "Linear",       params = {{"a (slope)",2},{"b (base)",16}},                         f = function(t,p) return p[1]*t + p[2] end},
    {name = "Quadratic",    params = {{"a",0.5},{"b",0},{"c",16}},                              f = function(t,p) return p[1]*t^2 + p[2]*t + p[3] end},
    {name = "Cubic",        params = {{"a",0.1},{"b",0},{"c",0},{"d",16}},                      f = function(t,p) return p[1]*t^3 + p[2]*t^2 + p[3]*t + p[4] end},
    {name = "Sine",         params = {{"amp",20},{"freq",1},{"phase",0},{"base",30}},           f = function(t,p) return p[1]*math.sin(p[2]*t + p[3]) + p[4] end},
    {name = "Cosine",       params = {{"amp",20},{"freq",1},{"phase",0},{"base",30}},           f = function(t,p) return p[1]*math.cos(p[2]*t + p[3]) + p[4] end},
    {name = "Tangent",      params = {{"a",5},{"b",0.5},{"base",30}},                           f = function(t,p) return math.clamp(p[1]*math.tan(p[2]*t), -100, 100) + p[3] end},
    {name = "Exponential",  params = {{"a",16},{"b (rate)",0.2}},                               f = function(t,p) return p[1]*math.exp(p[2]*t) end},
    {name = "Logarithmic",  params = {{"a",15},{"b",1},{"c",16}},                               f = function(t,p) return p[1]*math.log(math.max(p[2]*t,0)+1) + p[3] end},
    {name = "Square Root",  params = {{"a",15},{"b",1},{"c",16}},                               f = function(t,p) return p[1]*math.sqrt(math.max(p[2]*t,0)) + p[3] end},
    {name = "Absolute V",   params = {{"a",8},{"center",5},{"base",16}},                        f = function(t,p) return p[1]*math.abs(t - p[2]) + p[3] end},
    {name = "Sigmoid",      params = {{"max",60},{"steep",1},{"midpoint",5}},                   f = function(t,p) return p[1]/(1 + math.exp(-p[2]*(t - p[3]))) end},
    {name = "Gaussian",     params = {{"peak",50},{"center",5},{"width",1.5},{"base",16}},      f = function(t,p) return p[1]*math.exp(-((t-p[2])^2)/(2*math.max(p[3],0.01)^2)) + p[4] end},
    {name = "Sawtooth",     params = {{"amp",30},{"freq",0.5},{"base",16}},                     f = function(t,p) return p[1]*((t*p[2])%1) + p[3] end},
    {name = "Square Wave",  params = {{"high",50},{"low",16},{"freq",0.5}},                     f = function(t,p) return ((t*p[3])%1 < 0.5) and p[1] or p[2] end},
    {name = "Triangle Wave",params = {{"amp",30},{"freq",0.5},{"base",16}},                     f = function(t,p) local x=(t*p[2])%1 return p[1]*(1-math.abs(2*x-1)) + p[3] end},
    {name = "Damped Sine",  params = {{"amp",40},{"freq",3},{"decay",0.3},{"base",30}},         f = function(t,p) return p[1]*math.exp(-p[3]*t)*math.sin(p[2]*t) + p[4] end},
    {name = "Bounce",       params = {{"amp",40},{"freq",3},{"decay",0.25},{"base",16}},        f = function(t,p) return p[1]*math.abs(math.sin(p[2]*t))*math.exp(-p[3]*t) + p[4] end},
    {name = "Step",         params = {{"step size",8},{"interval",2},{"base",16}},              f = function(t,p) return p[3] + p[1]*math.floor(t/math.max(p[2],0.01)) end},
    {name = "Power",        params = {{"a",4},{"exponent",1.5},{"base",16}},                    f = function(t,p) return p[1]*math.max(t,0)^p[2] + p[3] end},
    {name = "Reciprocal",   params = {{"a",100},{"b",1},{"base",10}},                           f = function(t,p) return p[1]/(t + math.max(p[2],0.01)) + p[3] end},
}


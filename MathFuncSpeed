graphArea:GetPropertyChangedSignal("AbsoluteSize"):Connect(drawGraph)

--========================================================
-- EXECUTION LOOP (drives WalkSpeed + indicator)
--========================================================
local elapsed = 0
RunService.Heartbeat:Connect(function(dt)
    local char = player.Character
    local hum = char and char:FindFirstChildOfClass("Humanoid")
    if not running or not selectedFn or not hum then
        if not running then indicator.Visible = false; elapsed = 0 end
        return
    end

    local dur = getDuration()
    elapsed += dt
    if elapsed >= dur then
        if loopOn then elapsed %= dur else running = false; elapsed = dur end
    end

    local ok, v = pcall(selectedFn.f, elapsed, getParams())
    local speed = (ok and typeof(v)=="number" and v==v) and math.clamp(v, 0, MAX_SPEED) or hum.WalkSpeed
    hum.WalkSpeed = speed

    -- position indicator on graph using same normalization as the drawn curve
    local w, h = graphArea.AbsoluteSize.X, graphArea.AbsoluteSize.Y
    local raw = math.clamp(ok and v or 0, sampled.min, sampled.max)
    indicator.Visible = true
    indicator.Position = UDim2.fromOffset((elapsed/dur)*w, h - ((raw - sampled.min)/(sampled.max - sampled.min))*h)
    graphInfo.Text = string.format("%s | t = %.2fs | speed = %.1f", selectedFn.name, elapsed, speed)

    if not running then indicator.Visible = false end
end)

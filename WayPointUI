-- ── Button factory ────────────────────────────────────────────
local function mkBtn(label, col)
	local b = Instance.new("TextButton", panel)
	b.Size             = UDim2.new(1, 0, 0, 46)
	b.BackgroundColor3 = col
	b.BorderSizePixel  = 0
	b.AutoButtonColor  = false
	b.Text             = label
	b.TextSize         = 13
	b.Font             = Enum.Font.GothamBold
	b.TextColor3       = Color3.new(1, 1, 1)
	Instance.new("UICorner", b).CornerRadius = UDim.new(0, 9)

	-- Press-scale feedback (works on touch too)
	b.MouseButton1Down:Connect(function()
		TweenService:Create(b, TweenInfo.new(0.07), {Size = UDim2.new(0.965, 0, 0, 46)}):Play()
	end)
	b.MouseButton1Up:Connect(function()
		TweenService:Create(b, TweenInfo.new(0.1), {Size = UDim2.new(1, 0, 0, 46)}):Play()
	end)

	return b
end

local setBtn = mkBtn("📍   Set Waypoint",    C_SET)
local tpBtn  = mkBtn("⚡   Teleport Here",   C_TP)
local delBtn = mkBtn("🗑   Delete Waypoint", C_DEL)

-- ═══════════════════════════════════════════════════════════════
--  WORLD MARKER
-- ═══════════════════════════════════════════════════════════════

local function spawnMarker(cf)
	-- Clean up previous marker
	if markerPart then markerPart:Destroy()    end
	if markerConn then markerConn:Disconnect() end

	local pos = cf.Position

	markerPart = Instance.new("Part", workspace)
	markerPart.Name       = "WaypointMarker"
	markerPart.Anchored   = true
	markerPart.CanCollide = false
	markerPart.CastShadow = false
	markerPart.Size       = Vector3.new(3, 0.25, 3)
	markerPart.Material   = Enum.Material.Neon
	markerPart.Color      = Color3.fromRGB(90, 145, 255)
	markerPart.CFrame     = CFrame.new(pos)

	-- Flat spinning disc
	local mesh = Instance.new("SpecialMesh", markerPart)
	mesh.MeshType = Enum.MeshType.Cylinder
	mesh.Scale    = Vector3.new(0.12, 3, 3)

	-- World-space billboard label (always faces camera, always on top)
	local bb = Instance.new("BillboardGui", markerPart)
	bb.Size        = UDim2.fromOffset(95, 28)
	bb.StudsOffset = Vector3.new(0, 5, 0)
	bb.AlwaysOnTop = true

	local bLbl = Instance.new("TextLabel", bb)
	bLbl.Size                 = UDim2.new(1, 0, 1, 0)
	bLbl.BackgroundColor3     = BG
	bLbl.BackgroundTransparency = 0.2
	bLbl.Text                 = "📍 Waypoint"
	bLbl.TextSize             = 13
	bLbl.Font                 = Enum.Font.GothamBold
	bLbl.TextColor3           = Color3.new(1, 1, 1)
	bLbl.TextXAlignment       = Enum.TextXAlignment.Center
	Instance.new("UICorner", bLbl).CornerRadius = UDim.new(0, 6)

	-- Spin loop
	local ang = 0
	markerConn = RunService.Heartbeat:Connect(function(dt)
		if not markerPart or not markerPart.Parent then
			markerConn:Disconnect()
			return
		end
		ang = ang + dt * 50
		markerPart.CFrame = CFrame.new(pos) * CFrame.Angles(0, math.rad(ang), 0)
	end)
end

local function destroyMarker()
	if markerPart then markerPart:Destroy();    markerPart = nil end
	if markerConn then markerConn:Disconnect(); markerConn = nil end
end

-- ═══════════════════════════════════════════════════════════════
--  BUTTON ENABLE / DISABLE
-- ═══════════════════════════════════════════════════════════════

local function setEnabled(btn, on, activeCol)
	btn.Interactable     = on
	btn.BackgroundColor3 = on and activeCol or C_DIM
	btn.TextColor3       = on and Color3.new(1, 1, 1) or Color3.fromRGB(85, 85, 110)
end

local function refreshButtons()
	local has = waypointCF ~= nil
	setEnabled(tpBtn,  has, C_TP)
	setEnabled(delBtn, has, C_DEL)
end

refreshButtons()

-- ═══════════════════════════════════════════════════════════════
--  BUTTON LOGIC
-- ═══════════════════════════════════════════════════════════════

setBtn.MouseButton1Click:Connect(function()
	if not hrp then return end
	waypointCF = hrp.CFrame
	spawnMarker(waypointCF)
	refreshButtons()
	status.Text       = "✅  Waypoint saved!"
	status.TextColor3 = Color3.fromRGB(100, 200, 255)
end)

tpBtn.MouseButton1Click:Connect(function()
	if not (waypointCF and hrp) then return end
	-- Offset upward slightly so player doesn't clip into the ground
	hrp.CFrame        = waypointCF + Vector3.new(0, 3.5, 0)
	status.Text       = "⚡  Teleported!"
	status.TextColor3 = Color3.fromRGB(80, 235, 140)
end)

delBtn.MouseButton1Click:Connect(function()
	if not waypointCF then return end
	waypointCF = nil
	destroyMarker()
	refreshButtons()
	status.Text       = "🗑  Waypoint deleted"
	status.TextColor3 = Color3.fromRGB(220, 70, 70)
	-- Reset text after a short pause
	task.delay(2.5, function()
		if not waypointCF then
			status.Text       = "No waypoint set"
			status.TextColor3 = Color3.fromRGB(125, 125, 160)
		end
	end)
end)

-- ── Live distance display ─────────────────────────────────────
RunService.Heartbeat:Connect(function()
	if not (waypointCF and hrp) then return end
	local dist = math.round((hrp.Position - waypointCF.Position).Magnitude)
	if dist <= 6 then
		status.Text       = "✅  You're here!  (" .. dist .. " studs)"
		status.TextColor3 = Color3.fromRGB(80, 235, 140)
	elseif dist <= 50 then
		status.Text       = "📍  " .. dist .. " studs  ·  getting close!"
		status.TextColor3 = Color3.fromRGB(255, 210, 60)
	else
		status.Text       = "📍  " .. dist .. " studs away"
		status.TextColor3 = Color3.fromRGB(110, 195, 255)
	end
end)

-- ═══════════════════════════════════════════════════════════════
--  MINIMIZE / EXPAND
-- ═══════════════════════════════════════════════════════════════

minBtn.MouseButton1Click:Connect(function()
	minimized   = not minimized
	minBtn.Text = minimized and "+" or "−"
	TweenService:Create(main, EASE, {
		Size = UDim2.fromOffset(W, minimized and H_MINI or H_FULL)
	}):Play()
	if minimized then
		panel.Visible = false
	else
		task.delay(0.14, function() panel.Visible = true end)
	end
end)

-- ═══════════════════════════════════════════════════════════════
--  DRAGGING — title bar, mouse + touch
-- ═══════════════════════════════════════════════════════════════

local dragActive  = false
local dragInp     = nil
local dragStart   = nil
local dragPos0    = nil

-- Attach drag to the title bar so the minimize button doesn't conflict
-- (TextButton children consume input before it reaches the parent Frame)
bar.InputBegan:Connect(function(inp)
	if inp.UserInputType ~= Enum.UserInputType.MouseButton1
	and inp.UserInputType ~= Enum.UserInputType.Touch then return end
	dragActive = true
	dragInp    = inp
	dragStart  = inp.Position
	dragPos0   = main.Position
end)

UserInputService.InputChanged:Connect(function(inp)
	if not dragActive or inp ~= dragInp then return end
	local d  = inp.Position - dragStart
	local ss = sg.AbsoluteSize
	local fs = main.AbsoluteSize
	-- Clamp so the window can't be dragged off-screen
	main.Position = UDim2.fromOffset(
		math.clamp(dragPos0.X.Offset + d.X, 0, ss.X - fs.X),
		math.clamp(dragPos0.Y.Offset + d.Y, 0, ss.Y - fs.Y)
	)
end)

UserInputService.InputEnded:Connect(function(inp)
	if inp == dragInp then
		dragActive = false
		dragInp    = nil
	end
end)

-- ================================================================
--  WaypointUI.lua  |  LocalScript → StarterPlayerScripts
-- ================================================================
--  Features:
--    ◆ Draggable title bar — mouse & touch (mobile-compatible)
--    ◆ Minimize / expand with smooth tween animation
--    ◆ [📍 Set Waypoint]    saves your current position + spawns
--                            a spinning neon disc marker in-world
--    ◆ [⚡ Teleport Here]   moves you instantly to the waypoint
--    ◆ [🗑 Delete Waypoint] removes waypoint & world marker
--    ◆ Live distance counter (color-coded: far / close / arrived)
--    ◆ Teleport / Delete buttons auto-dim when no waypoint is set
--    ◆ Respawn-safe character tracking
-- ================================================================

local Players          = game:GetService("Players")
local RunService       = game:GetService("RunService")
local TweenService     = game:GetService("TweenService")
local UserInputService = game:GetService("UserInputService")

local player    = Players.LocalPlayer
local playerGui = player:WaitForChild("PlayerGui")

-- ── Character helpers (respawn-safe) ─────────────────────────
local chr, hrp, hum

local function grabChar(c)
	chr = c
	hrp = c:WaitForChild("HumanoidRootPart")
	hum = c:WaitForChild("Humanoid")
end

if player.Character then grabChar(player.Character) end
player.CharacterAdded:Connect(grabChar)

